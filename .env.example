# Compose profile
MULTIDB_PROFILE=dev

# Master config
MASTER_NODE_ID=master-1
MASTER_RPC_PORT=7100
MASTER_HTTP_PORT=7000
MASTER_CPU_LIMIT=1.0
MASTER_MEM_LIMIT=512M

# TServer limits
TSERVER_CPU_LIMIT=1.0
TSERVER_MEM_LIMIT=512M

# Stress profile resource limits
LOADGEN_CPU_LIMIT=1.0
LOADGEN_MEM_LIMIT=512M

# Optional profile flags (use compose --profile)
# stress
# fault
